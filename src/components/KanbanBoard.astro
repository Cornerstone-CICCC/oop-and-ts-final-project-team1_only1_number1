---
import "./../styles/task.css";
---

<div id="container">
  <!-- Search -->

  <div class="board-wrap">
    <!-- todo -->
    <div class="board todo">
      <div class="board-header">
        <h3>TODO</h3>
        <!-- click this button open modal -->
        <button id="add-todo-button">
          <img src="/src/assets/plus.svg" alt="Add task" width="20" height="20" />
        </button>
      </div>
      <ul class="task-zone" id="todo-task-zone" data-column>
        <!-- individaul task -->
      </ul>
    </div>
    <!-- // todo -->

    <!-- progress -->
    <div class="board progress">
      <div class="board-header">
        <h3>PROGRESS</h3>
        <button id="add-progress-button">
          <img src="/src/assets/plus.svg" alt="Add task" width="20" height="20" />
        </button>
      </div>
      <ul class="task-zone" id="progress-task-zone" data-column>
        <!-- individaul task -->
      </ul>
    </div>
    <!-- // progress -->

    <!-- done -->
    <div class="board done">
      <div class="board-header">
        <h3>DONE</h3>
        <button id="add-done-button">
          <img src="/src/assets/plus.svg" alt="Add task" width="20" height="20" />
        </button>
      </div>
      <ul class="task-zone" id="done-task-zone" data-column>
        <!-- individaul task -->
      </ul>
    </div>
    <!-- // done -->
  </div>

  <script src="../ts/TaskManager.ts"></script>

  <style>
    #container {
      height: calc(100vh - 100px); /* templorary */
    }
    .board-wrap {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      height: 100%; /* templorary */
    }
    .board {
      padding: 8px;
    }
    .board.todo {
      background-color: #f2bd19;
    }
    .board.progress {
      background-color: #f23f41;
    }
    .board.done {
      background-color: #0bbf8e;
    }
    .board h3 {
      color: #fff;
    }
    .task-zone {
      min-height: 50px; /* temporary for available drag and drop */
    }

    .board-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 16px;
    }

    .board-header button {
      padding: 4px 8px;
      border-radius: 4px;
      border: none;
      cursor: pointer;
    }

    /* Add mobile styles */
    @media (max-width: 768px) {
      .board-wrap {
        grid-template-columns: 1fr;
        gap: 24px;
        height: auto;
      }
      .board {
        max-width: 100%;
        overflow-x: hidden; /* Prevent board from extending */
      }
      .task-zone {
        display: flex;
        overflow-x: auto;
        overflow-y: hidden;
        padding-bottom: 16px;
        gap: 16px;
        width: 100%;
        scroll-behavior: smooth;
      }
    }
  </style>
</div>
