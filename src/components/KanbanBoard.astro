---
import "./../styles/task.css";
import { Image } from "astro:assets";
import TODO from "../assets/TODO.png";
import PROGRESS from "../assets/PROGRESS.png";
import DONE from "../assets/DONE.png";
---

<div id="container">
  <!-- Search -->

  <div class="board-wrap">
    <!-- todo -->
    <div class="board todo">
      <div class="task-name">
        <Image src={TODO} alt="TODO" width={100} height={33.3} />
      </div>
      <ul class="task-zone" id="todo-task-zone" data-column>
        <!-- individaul task -->
      </ul>
      <div>
        <!-- click this button open modal -->
        <button id="add-todo-button">Add Task</button>
      </div>
    </div>
    <!-- // todo -->

    <!-- progress -->
    <div class="board progress">
      <div class="task-name">
        <Image src={PROGRESS} alt="PROGRESS" width={168} height={33.3} />
      </div>
      <ul class="task-zone" id="progress-task-zone" data-column>
        <!-- individaul task -->
      </ul>
      <div>
        <!-- click this button open modal -->
        <button id="add-progress-button">Add Task</button>
      </div>
    </div>
    <!-- // progress -->

    <!-- done -->
    <div class="board done">
      <div class="task-name">
        <Image src={DONE} alt="DONE" width={100} height={33.3} />
      </div>
      <ul class="task-zone" id="done-task-zone" data-column>
        <!-- individaul task -->
      </ul>
      <div>
        <!-- click this button open modal -->
        <button id="add-done-button">Add Task</button>
      </div>
    </div>
    <!-- // done -->
  </div>
</div>

<script src="../ts/TaskManager.ts"></script>

<style>
  #container {
    height: calc(100vh - 100px); /* templorary */
  }
  .board-wrap {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    height: 100%; /* templorary */
  }
  .board {
    padding: 8px;
  }
  .board.todo {
    background-color: #f2bd19;
  }
  .board.progress {
    background-color: #f23f41;
  }
  .board.done {
    background-color: #0bbf8e;
  }
  .board h3 {
    color: #fff;
  }
  .task-zone {
    min-height: 50px; /* temporary for available drag and drop */
  }
</style>
