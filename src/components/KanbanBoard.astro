---
import "./../styles/task.css";
import { Image } from "astro:assets";
import TODO from "../assets/TODO.png";
import PROGRESS from "../assets/PROGRESS.png";
import DONE from "../assets/DONE.png";
---

<div id="container">
  <!-- Search -->

  <div class="board-wrap">
    <!-- todo -->
    <div class="board todo">
      <div class="board-header">
        <div class="task-name">
          <Image src={TODO} alt="TODO" width={100} height={33.3} />
        </div>
        <!-- click this button open modal -->
        <button id="add-todo-button">
          <img
            src="/src/assets/plus.svg"
            alt="Add task"
            width="20"
            height="20"
          />
        </button>
      </div>
      <ul class="task-zone" id="todo-task-zone" data-column>
        <!-- individaul task -->
      </ul>
    </div>
    <!-- // todo -->

    <!-- progress -->
    <div class="board progress">
      <div class="board-header">
        <div class="task-name">
          <Image src={PROGRESS} alt="PROGRESS" width={168} height={33.3} />
        </div>
        <button id="add-progress-button">
          <img
            src="/src/assets/plus.svg"
            alt="Add task"
            width="20"
            height="20"
          />
        </button>
      </div>
      <ul class="task-zone" id="progress-task-zone" data-column>
        <!-- individaul task -->
      </ul>
    </div>
    <!-- // progress -->

    <!-- done -->
    <div class="board done">
      <div class="board-header">
        <div class="task-name">
          <Image src={DONE} alt="DONE" width={100} height={33.3} />
        </div>
        <button id="add-done-button">
          <img
            src="/src/assets/plus.svg"
            alt="Add task"
            width="20"
            height="20"
          />
        </button>
      </div>
      <ul class="task-zone" id="done-task-zone" data-column>
        <!-- individaul task -->
      </ul>
    </div>
    <!-- // done -->
  </div>

  <script src="../ts/TaskManager.ts"></script>

  <style>
    .board-wrap {
      display: flex;
      height: 100%; /* templorary */
      margin-left: -8px;
      margin-right: -8px;
    }
    .board {
      min-width: calc(33.33% - 16px);
      margin: 8px;
      padding: 16px;
      min-height: calc(100vh - 185px);
    }
    .board.todo {
      background-color: #f2bd19;
    }
    .board.progress {
      background-color: #f23f41;
    }
    .board.done {
      background-color: #0bbf8e;
    }
    .board h3 {
      color: #fff;
    }
    .task-zone {
      min-height: 50px; /* temporary for available drag and drop */
    }

    .board-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 16px;
    }

    .board-header button {
      padding: 4px 8px;
      border-radius: 4px;
      border: none;
      cursor: pointer;
    }

    /* Add mobile styles */
    @media (max-width: 768px) {
      .board-wrap {
        grid-template-columns: 1fr;
        gap: 24px;
        height: auto;
        display: block;
        margin: 0;
      }
      .board {
        min-height: auto;
        margin: 0;
      }
      .task-zone {
        display: flex;
        overflow-x: auto;
        overflow-y: hidden;
        padding-bottom: 16px;
        gap: 16px;
        width: 100%;
        scroll-behavior: smooth;
      }
    }
  </style>
</div>
